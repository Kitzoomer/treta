# TRETA environment template (safe placeholders only)

# Runtime
TRETA_ENV=local
TRETA_TIMEZONE=Asia/Bangkok
TRETA_SCAN_HOUR=9

# Security/API
TRETA_API_TOKEN=
OPENAI_API_KEY=
GUMROAD_ACCESS_TOKEN=

# Integrations
OPENCLAW_BASE_URL=http://openclaw:8080
OPENCLAW_TIMEOUT_SECONDS=5

# Autonomy/policy
AUTONOMY_MODE=manual
STRATEGY_DECISION_COOLDOWN_MINUTES=10
ACTION_EXECUTION_TIMEOUT_SECONDS=300
ACTION_APPROVAL_MIN_RISK_LEVEL=high
ACTION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=2
ACTION_CIRCUIT_BREAKER_WINDOW_SECONDS=600

# Strategic loop
STRATEGY_LOOP_ENABLED=true
STRATEGY_LOOP_INTERVAL_SECONDS=900
STRATEGY_LOOP_MAX_PENDING=5

# HTTP limits
TRETA_MAX_REQUEST_BODY_BYTES=1048576
TRETA_MAX_EVENTS_PER_CYCLE=120
